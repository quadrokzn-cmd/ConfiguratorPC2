# QuadroTech platform environment config.
# Copy to .env before running `make up`.

# --- App ---
APP_HOST=0.0.0.0
APP_PORT=8000
APP_ENV=dev
LOG_LEVEL=INFO

# --- Database ---
# Inside docker-compose the app reaches postgres by service name.
DATABASE_URL=postgresql+psycopg2://quadrotech:quadrotech@postgres:5432/quadrotech
# For scripts/migrate.py run from host (outside docker):
DATABASE_URL_LOCAL=postgresql+psycopg2://quadrotech:quadrotech@localhost:5432/quadrotech

POSTGRES_USER=quadrotech
POSTGRES_PASSWORD=quadrotech
POSTGRES_DB=quadrotech

# --- Basic Auth ---
# Comma-separated "login:password" pairs. No bcrypt, plain comparison only.
BASIC_AUTH_USERS=manager:pwd1,owner:pwd2

# --- LLM budget guard (stub, not active in MVP) ---
LLM_BUDGET_ENABLED=false
LLM_BUDGET_DAILY_RUB=100

# --- Notifications (email-agent HTTP endpoint, активируется в Волне 3Б) ---
EMAIL_AGENT_URL=
EMAIL_AGENT_TOKEN=
