# Пример файла переменных окружения. Скопируйте в .env и подставьте свои значения.
DATABASE_URL=postgresql://user:password@localhost:5432/kvadro_tech
OPENAI_API_KEY=sk-...

# --- OpenAI Web Search (этап 2.5В) ---
# Модель для обогащения новых SKU; по цене/качеству оптимальна mini-версия.
OPENAI_SEARCH_MODEL=gpt-4o-mini-search-preview

# Защита от трат. AUTO_LIMIT — до скольких новых SKU обогащаем без вопросов.
# MAX — жёсткий потолок: больше нельзя даже с согласием оператора.
OPENAI_ENRICH_AUTO_LIMIT=20
OPENAI_ENRICH_MAX=200

# Средняя стоимость одного запроса с web search (USD), используется в cost_guard.
# ~1500 input * $0.15/M + ~300 output * $0.60/M + ~$0.027 за web search ≈ $0.0275.
OPENAI_ENRICH_COST_PER_CALL_USD=0.0275

# Авто-запуск обогащения сразу после price_loader. Если добавленных SKU
# больше AUTO_LIMIT — хук не запустится и попросит ручной запуск CLI.
OPENAI_ENRICH_AUTO_HOOK=false

# Резервный курс USD→RUB, если ЦБ РФ недоступен (основной источник —
# https://www.cbr-xml-daily.ru/daily_json.js, с суточным кэшем).
OPENAI_ENRICH_USD_RUB_FALLBACK=95.0

# --- NLU (этап 4): парсер свободных запросов менеджера ---
# Модель для парсера запроса и комментатора результата подбора.
# Без web search; gpt-4o-mini оптимален по цене и качеству.
OPENAI_NLU_MODEL=gpt-4o-mini

# --- Веб-сервис (этап 5) ---
# Пароль, с которым при первом запуске scripts/create_admin.py создаётся
# пользователь с логином 'admin'. После создания эту строку можно
# обнулить — используется только один раз.
ADMIN_INITIAL_PASSWORD=changeme

# Секрет для подписи сессионных cookie. Рандомная длинная строка —
# сгенерируйте, например, через `python -c "import secrets; print(secrets.token_urlsafe(48))"`.
SESSION_SECRET_KEY=replace-me-with-a-long-random-string

# Дневной лимит расходов OpenAI на всю систему (в рублях). При достижении
# 80% — предупреждение админу; при 100% — новые запросы блокируются до
# следующего дня. Считается по api_usage_log.cost_rub за текущую дату.
DAILY_OPENAI_BUDGET_RUB=100

# URL тестовой БД (используется только pytest). База должна существовать;
# миграции 001-007 прогоняются автоматически в conftest.py.
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/configurator_pc_test
