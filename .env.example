# =============================================================
# Шаблон файла переменных окружения. Скопируйте в .env и
# заполните своими значениями. .env в git НЕ коммитится.
# =============================================================
# Подробное описание каждой переменной — в docs/deployment.md.

# --- APP_*: общие настройки приложения (этап 10.1) ---------------------

# Среда исполнения. На "production" включаются строгие проверки:
# secure cookies, обязательный APP_SECRET_KEY. Локально оставляйте
# development (или просто пусто).
APP_ENV=development

# Порт для uvicorn. Локально не обязателен (uvicorn запускается
# вручную с --port). На Railway переопределяется автоматически
# через $PORT, но переменная зарезервирована для совместимости.
APP_PORT=8080

# Секрет для подписи сессионных cookie. На production ОБЯЗАТЕЛЬНО
# задать собственный длинный ключ — без него сервис упадёт на старте.
# Сгенерировать: python -c "import secrets; print(secrets.token_urlsafe(48))"
# Старое имя SESSION_SECRET_KEY поддерживается для обратной совместимости.
APP_SECRET_KEY=replace-me-with-a-long-random-string

# Домен для сессионных cookie. Пусто/не задано — текущее однодоменное
# поведение (cookie живёт только на хосте, который её выдал). На Railway
# выставляется ".quadro.tatar" (с точкой), чтобы сессия шарилась
# с будущим app.quadro.tatar.
APP_COOKIE_DOMAIN=

# Логин/пароль администратора, которого scripts/bootstrap_admin.py
# создаёт при старте сервиса, если его ещё нет в БД. После создания
# скрипт пользователя НЕ трогает — пароль через эти переменные не
# меняется. Если переменные пусты — bootstrap молча пропускает шаг.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# --- DATABASE: основная БД ---------------------------------------------

# Подключение к PostgreSQL 16. На Railway плагин Postgres выдаёт
# DATABASE_URL автоматически — там этой строки в .env нет.
# Формат: postgresql+psycopg://user:pass@host:port/dbname
# (psycopg2-binary тоже работает с префиксом postgresql://).
DATABASE_URL=postgresql://user:password@localhost:5432/kvadro_tech

# URL тестовой БД (используется только pytest). Базу создавать
# заранее: CREATE DATABASE configurator_pc_test;
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/configurator_pc_test

# --- OPENAI_*: ключ и параметры моделей --------------------------------

# Ключ от OpenAI (https://platform.openai.com/api-keys). Без него
# модули NLU и enrichment запустить нельзя.
OPENAI_API_KEY=sk-your-key-here

# --- OpenAI Web Search (этап 2.5б) ---
# Модель для обогащения полей SKU; по цене/качеству оптимальна mini-серия.
OPENAI_SEARCH_MODEL=gpt-4o-mini-search-preview

# Лимиты на стоп. AUTO_LIMIT — на сколько новых SKU обогащаем без подтверждения.
# MAX — жёсткий потолок: больше нельзя даже с согласием оператора.
OPENAI_ENRICH_AUTO_LIMIT=20
OPENAI_ENRICH_MAX=200

# Средняя стоимость одного запроса с web search (USD), используется в cost_guard.
# ~1500 input * $0.15/M + ~300 output * $0.60/M + ~$0.027 за web search ≈ $0.0275.
OPENAI_ENRICH_COST_PER_CALL_USD=0.0275

# Авто-обогащение сразу после price_loader. Если необогащённых SKU
# больше AUTO_LIMIT — оно не запустится и попросит ручного запуска CLI.
OPENAI_ENRICH_AUTO_HOOK=false

# Резервный курс USD/RUB, если ЦБ недоступен (основной источник —
# https://www.cbr-xml-daily.ru/daily_json.js, в часовом меше).
OPENAI_ENRICH_USD_RUB_FALLBACK=95.0

# --- NLU (этап 4): разбор свободных пользовательских запросов ---
# Модель для разбора запроса с детерминированным результатом разбора.
# Без web search; gpt-4o-mini оптимален по цене и задержке.
OPENAI_NLU_MODEL=gpt-4o-mini

# --- Дневной бюджет OpenAI (этап 4) ------------------------------------
# Дневной лимит расходов OpenAI на всю систему (в рублях). При достижении
# 80% — предупреждение оператору; при 100% — новые запросы блокируются
# до следующего дня. Считается из api_usage_log.cost_rub за текущие сутки.
DAILY_OPENAI_BUDGET_RUB=100

# --- ADMIN_INITIAL_PASSWORD (legacy, этап 5) ---------------------------
# Пароль, с которым старый scripts/create_admin.py создавал пользователя
# 'admin' при первом ручном запуске. На Railway больше не используется —
# вместо него ADMIN_USERNAME / ADMIN_PASSWORD выше. Оставляем для
# совместимости с локальными dev-окружениями.
ADMIN_INITIAL_PASSWORD=changeme

# --- SCHEDULER_* (этап 10.1) -------------------------------------------
# Запускать ли APScheduler в этом инстансе. На локалке = 1, чтобы курс
# ЦБ автообновлялся. На Railway пока тоже = 1 (один инстанс). Когда
# появятся реплики — оставить только на одной, иначе cron-задачи будут
# дублироваться.
RUN_SCHEDULER=1

# --- SMTP_* (этап 8.3): отправка писем поставщикам ---------------------
# По умолчанию — mail.ru с ящика quadro@quadro.tatar. SMTP_APP_PASSWORD
# обязателен для реальной отправки; создаётся в mail.ru ЛК → Безопасность
# → Пароли для внешних приложений (обычный пароль от ящика не подойдёт,
# mail.ru его отвергнет с ошибкой 535). Без этой переменной preview/превью
# работают, но /emails/send выдаёт failed на каждого получателя.
SMTP_HOST=smtp.mail.ru
SMTP_PORT=465
SMTP_USE_SSL=true
SMTP_USER=quadro@quadro.tatar
SMTP_APP_PASSWORD=
# Архивная копия исходящих писем (читаемых самим в sendmail, без
# раскрытия Bcc в письме). Оставьте пустым, если не нужно хранить копии у себя.
SMTP_BCC=quadro@quadro.tatar
SMTP_FROM_NAME=КВАДРО-ТЕХ

PORTAL_URL=http://localhost:8081
CONFIGURATOR_URL=http://localhost:8080
APP_COOKIE_DOMAIN=
ALLOWED_REDIRECT_HOSTS=localhost:8080,localhost:8081
# --- Этап 12.3: Treolan API ---
TREOLAN_API_LOGIN="quadro_sa"
TREOLAN_API_PASSWORD="s4]O]h|W"
TREOLAN_API_BASE_URL="https://api.treolan.ru/api"
# --- Resurs Media SOAP API (этап 12.4-РМ + переход на prod 2026-05-12) ---
# Один URL, разные значения per environment:
#   * dev / preprod  → testapi.resurs-media.ru/test9/...
#   * production     → prod-URL из email Сергея Волкова (ГК Ресурс-Медиа)
# Скрипты scripts/resurs_media_smoke.py и
# scripts/resurs_media_bootstrap_catalog.py требуют флаг --allow-prod, если
# в URL нет подстроки 'test'.
RESURS_MEDIA_WSDL_URL=http://example.com/ws/WSAPI?wsdl
RESURS_MEDIA_USERNAME=
RESURS_MEDIA_PASSWORD=
RESURS_MEDIA_CLIENT_ID=
